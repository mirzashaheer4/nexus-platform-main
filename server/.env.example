# Server Configuration
PORT=5000
NODE_ENV=development

# Database Settings
MONGO_URI=mongodb://localhost:27017/nexus

# Authentication Secrets
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Client URL (CORS and redirects)
CLIENT_URL=http://localhost:3000

# Stripe Sandbox Settings
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Nodemailer / Email Settings (Fix 16)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# AWS S3 Settings (Week 2 - falls back to local uploads if empty)
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_BUCKET_NAME=your_s3_bucket_name
AWS_REGION=us-east-1
UPLOAD_PATH=uploads
